#! /usr/bin/env zsh

set -o pipefail

timestamp=$(date +"%Y-%m-%d_%H-%M-%S")
LOGFILE="logs/${timestamp}_setup.log"

mkdir -p logs
exec > >(tee -a "$LOGFILE") 2>&1

_log() {
    local level="$1" msg="$2"
    printf '%s [%s] %s\n' "$(date +"%Y-%m-%d %H:%M:%S")" "$level" "$msg"
}

_info() {
    _log "INFO" "$*"
    sleep 1
}

_error() {
    _log "ERROR" "$*"
    sleep 2
}

_warn() {
    _log "WARN" "$*"
    sleep 2
}

_echo_run() {
    _log "RUN" "$*"
    "$@" || _error "Command failed: $*"; return 1;
}

_clone_repo() {
    local repo_url="$1"
    local dest_path="$2"
    local description="${3:-repository}"
    local depth_flag="${4:+--depth=$4}"
    _info "Cloning $description to $dest_path..."
    _echo_run git clone $depth_flag "$repo_url" "$dest_path"
}

_ask_choice() {
    local prompt="$1"
    shift
    while true; do
        read -p "$prompt" -r
        for option in "$@"; do
            local keys="${option%%:*}"
            local value="${option#*:}"
            IFS='|' read -ra key_array <<< "$keys"
            for key in "${key_array[@]}"; do
                if [[ "$REPLY" == "$key" ]]; then
                    echo "$value"
                    return 0
                fi
            done
        done
        _warn "Invalid option"
    done
}

_ask_input() {
    local prompt="$1"
    local var_name="$2"
    while true; do
        read -p "$prompt" -r input
        if [[ -n "$input" ]]; then
            echo "$input"
            return 0
        fi
        _warn "No ${var_name} was provided"
    done
}

main() {
    _info "Setting up Mac with certain set of apps and setting up terminal environment with certain CLI tools"

    # Check if Homebrew is installed and install if not
    if ! command -v brew >/dev/null 2>&1; then
        _info "Homebrew not found. Installing Homebrew..."
        _log "RUN" "/bin/bash -c \"\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\""
        if ! /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"; then
            _error "Failed to install Homebrew"
            return 1
        fi
        _echo_run eval "$(/opt/homebrew/bin/brew shellenv)"

        _info "Tapping alternative cask versions..."
        _echo_run brew tap homebrew/cask-versions
    else
        _info "Homebrew is already installed. Updating Homebrew..."
        _echo_run brew update
    fi

    # Install Raycast
    _info "Installing Raycast (app to search and run commands)..."
    _echo_run brew install --cask raycast

    # Install Rectangle window manager
    _info "Installing Rectangle window manager..."
    _echo_run brew install --cask rectangle

    # Install and  configure Kitty
    _info "Installing kitty terminal emulator and Fira Code Nerd Font..."
    _echo_run brew tap homebrew/cask-fonts
    _echo_run brew install kitty --cask font-fira-code-nerd-font

    _clone_repo "https://github.com/Aapok0/kitty.git" "$HOME/.config/kitty" "kitty configuration" 1

    _info "Adding title bar back to help with mouse selection..."
    _echo_run sed -i "" "^hide_window_decorations.*/hide_window_decorations no/" "$HOME/.config/kitty/kitty.conf"

    # Configure ZSH

    _clone_repo "https://github.com/Aapok0/zsh.git" "$HOME/.config/zsh" "ZSH configuration" 1

    _info "Commenting out PATH variable rewrite..."
    _echo_run sed -i '' '/^export PATH=/ s/^/#/' "$HOME/.config/zsh/.zshrc"

    _info "Adding line to initialize Homebrew to .zshrc..."
    _echo_run sed -i "" "/export VISUAL='nvim'/r"<(
        echo ""
        echo ""
        echo "### HOMEBREW"
        echo 'eval "$(/opt/homebrew/bin/brew shellenv)"'
    ) "$HOME/.config/zsh/.zshrc"

    _info "Installing coreutils and adding it to path to get dircolors working..."
    _echo_run brew install coreutils
    _echo_run sed -i "" "/eval \"\$(/opt/homebrew/bin/brew shellenv)\"/r"<(
        echo ""
        echo ""
        echo "### COREUTILS FOR DIRCOLOR"
        echo 'PATH="/opt/homebrew/opt/coreutils/libexec/gnubin:$PATH"'
    ) "$HOME/.config/zsh/.zshrc"

    # This was recently changed to...? Starship?
    choice=$(_ask_choice "Which prompt theme would you like to install, (P)owerlevel10k or (s)paceship: " \
        '|P|p|Powerlevel10k|powerlevel10k|Powelevel|powerlevel:powerlevel10k' \
        'S|s|Spaceship|spaceship:spaceship')
    
    case "$choice" in
        powerlevel10k)
            _clone_repo "https://github.com/romkatv/powerlevel10k.git" "$HOME/.config/zsh/themes/powerlevel10k" "PowerLevel10k theme" 1
            ;;
        spaceship)
            _clone_repo "https://github.com/spaceship-prompt/spaceship-prompt.git" "$HOME/.config/zsh/themes/spaceship-prompt" "Spaceship theme" 1
            ;;
    esac

    _info "Installing ZSH plugins Fast-Syntax-Highlighting, ZSH-Autosuggestions and ZSH-Completions..."
    _clone_repo "https://github.com/zdharma-continuum/fast-syntax-highlighting.git" "$HOME/.config/zsh/plugins/fast-syntax-highlighting" "fast-syntax-highlighting" 1
    _clone_repo "https://github.com/zsh-users/zsh-autosuggestions.git" "$HOME/.config/zsh/plugins/zsh-autosuggestions" "zsh-autosuggestions" 1
    _clone_repo "https://github.com/zsh-users/zsh-completions.git" "$HOME/.config/zsh/plugins/zsh-completions" "zsh-completions" 1

    _info "Installing CLI tools: wget, python3, neovim, tmux, eza, bat, htop, ripgrep, xclip, zoxide, fzf, fd, tfswitch, telnet, tcptraceroute, azure-cli, gh, ffmpeg, tlrc, thefuck and nb..."
    _echo_run brew install \
        wget python3 node neovim tmux eza bat htop ripgrep xclip zoxide fzf fd \
        warrensbox/tap/tfswitch telnet tcptraceroute azure-cli gh ffmpeg tlrc thefuck nb

    _clone_repo "https://github.com/junegunn/fzf-git.sh.git" "$HOME/.config/zsh/tools/fzf-git.sh" "fzf-git" 1

    _info "Changing fdfind commands to fd in .zshrc..."
    _echo_run sed -i "" "s/fdfind/fd/g" "$HOME/.config/zsh/.zshrc"

    _info "Installing Catppuccin Mocha theme for bat..."
    _echo_run mkdir -p "$(bat --config-dir)/themes"
    _echo_run wget -P "$(bat --config-dir)/themes" https://github.com/catppuccin/bat/raw/main/themes/Catppuccin%20Mocha.tmTheme
    _echo_run bat cache --build

    _info "Creating symlink of .zshenv to home directory..."
    _echo_run ln -s "$HOME/.config/zsh/.zshenv" "$HOME/.zshenv"

    # Neovim
    _info "Installing Neovim..."
    _echo_run brew install neovim
    _clone_repo "https://github.com/Aapok0/nvim.git" "$HOME/.config/nvim" "Neovim configuration" 1

    # tmux
    _info "Installing tmux..."
    _echo_run brew install tmux
    _clone_repo "https://github.com/Aapok0/tmux.git" "$HOME/.config/tmux" "tmux configuration" 1
    _clone_repo "https://github.com/tmux-plugins/tpm" "$HOME/.tmux/plugins/tpm" "tmux package manager" 1
    _clone_repo "https://github.com/Aapok0/tmux-tools.git" "$HOME/.config/tmux/tmux-tools" "tmux-tools" 1

    _info "Creating symbolic links for tmux tools..."
    _echo_run sudo ln -s "$HOME/.config/tmux/tmux-tools/tmuxz" /usr/local/bin/tmuxz
    _echo_run sudo ln -s "$HOME/.config/tmux/tmux-tools/tmuxf" /usr/local/bin/tmuxf

    # Add gitconfig
    _clone_repo "https://github.com/Aapok0/gitconfig.git" "$HOME/.config/gitconfig" "gitconfig" 1
    _info "Copying gitconfig to home directory..."
    _echo_run cp "$HOME/.config/gitconfig/.gitconfig" "$HOME/.gitconfig"

    git_name=$(_ask_input "Give your first and last name to be set for your name in git: " "name")
    _echo_run sed -i "" "s/name =/name = $git_name/" "$HOME/.gitconfig"
    _info "Name '$git_name' has been inserted into gitconfig"

    git_email=$(_ask_input "Give your email to be set as your email in git: " "email")
    _echo_run sed -i "" "s/email =/email = $git_email/" "$HOME/.gitconfig"
    _info "Email '$git_email' has been inserted into gitconfig"

    # SSH key
    choice=$(_ask_choice "Do you want to create an SSH key? (Y/n): " \
        '|Y|y|Yes|yes:yes' \
        'N|n|No|no:no')
    
    if [[ "$choice" == "yes" ]]; then
        ssh_email=$(_ask_input "Enter your email for the SSH key: " "email")
        read -p "Enter key name (press Enter for default 'id_ed25519'): " -r key_name
        key_name="${key_name:-id_ed25519}"
        
        _info "Creating SSH key..."
        _echo_run ssh-keygen -t ed25519 -C "$ssh_email" -f "$HOME/.ssh/$key_name"
        _info "Starting SSH agent..."
        eval "$(ssh-agent -s)"
        _info "Adding SSH key to agent..."
        _echo_run ssh-add "$HOME/.ssh/$key_name"
        _info "SSH key has been created at $HOME/.ssh/$key_name"
    else
        _info "Skipping SSH key creation"
    fi

    # Menu bar apps installation
    _info "Installing menu bar apps: hiddenbar, stats, and itsycal..."
    _echo_run brew install --cask hiddenbar stats itsycal

    # Installing rest of the apps
    choice=$(_ask_choice "Which password manager(s) do you want to install? (B)itwarden, (k)eepassxc, b(o)th, or (n)one: " \
        '|B|b|Bitwarden|bitwarden:bitwarden' \
        'K|k|Keepassxc|keepassxc:keepassxc' \
        'O|o|Both|both:both' \
        'N|n|None|none:none')
    
    case "$choice" in
        bitwarden)
            _info "Installing Bitwarden..."
            _echo_run brew install --cask bitwarden
            ;;
        keepassxc)
            _info "Installing KeePassXC..."
            _echo_run brew install --cask keepassxc
            ;;
        both)
            _info "Installing Bitwarden and KeePassXC..."
            _echo_run brew install --cask bitwarden keepassxc
            ;;
        none)
            _info "Skipping password manager installation"
            ;;
    esac

    choice=$(_ask_choice "Which Firefox version do you want to install? (R)egular, (d)eveloper edition, (b)oth, or (n)one: " \
        '|R|r|Regular|regular:regular' \
        'D|d|Developer|developer:developer' \
        'B|b|Both|both:both' \
        'N|n|None|none:none')
    
    case "$choice" in
        regular)
            _info "Installing Firefox..."
            _echo_run brew install --cask firefox
            ;;
        developer)
            _info "Installing Firefox Developer Edition..."
            _echo_run brew install --cask homebrew/cask-versions/firefox-developer-edition
            ;;
        both)
            _info "Installing Firefox and Firefox Developer Edition..."
            _echo_run brew install --cask firefox homebrew/cask-versions/firefox-developer-edition
            ;;
        none)
            _info "Skipping Firefox installation"
            ;;
    esac

    _info "Installing Docker Desktop..."
    _echo_run brew install --cask docker

    _info "Installing kubelogin and helm..."
    _echo_run brew install Azure/kubelogin/kubelogin helm

    _info "Installing Wireshark..."
    _echo_run brew install --cask wireshark

    _info "Installing media apps: VLC and Spotify..."
    _echo_run brew install --cask vlc spotify

    _info "Installing Android File Transfer..."
    _echo_run brew install --cask android-file-transfer

    _info "Setup complete! Please review the README.md for manual configuration steps"
}

main || { _error "Setup script failed!"; exit 1; }
