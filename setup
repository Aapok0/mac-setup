#!/usr/bin/env zsh

set -o pipefail

timestamp=$(date +"%Y-%m-%d_%H-%M-%S")
LOGFILE="logs/${timestamp}_setup.log"

mkdir -p logs
exec > >(tee -a "$LOGFILE") 2>&1

_log() {
    local level="$1" msg="$2"
    printf "[%s] %s: %s\n" "$(date '+%Y-%m-%d %H:%M:%S')" "$level" "$msg"
}

_info() {
    _log "INFO" "$*"
    sleep 1
}

_info_long() {
    _log "INFO" "$*"
    sleep 2
}

_error() {
    _log "ERROR" "$*"
    sleep 2
}

_warn() {
    _log "WARN" "$*"
}

_echo_run() {
    _log "RUN" "$*"
    "$@" || { _error "Command failed: $*"; return 1; }
}

_to_ssh_url() {
    local url=$1
    echo "$url" | sed 's|https://github\.com/|git@github.com:|'
}

_set_ssh_remote() {
    local repo_path=$1
    cd "$repo_path" || return 1
    local https_url=$(git config --get remote.origin.url)
    local ssh_url=$(_to_ssh_url "$https_url")
    if [ "$https_url" != "$ssh_url" ]; then
        _echo_run git remote set-url origin "$ssh_url"
    fi
    cd - > /dev/null || return 1
}

_ask_choice() {
    local prompt="$1"
    shift
    while true; do
        read "REPLY?$prompt"
        for option in "$@"; do
            local keys="${option%%:*}"
            local value="${option#*:}"
            local key_array=("${(@s:|:)keys}")
            for key in "${key_array[@]}"; do
                if [[ "$REPLY" == "$key" ]]; then
                    echo "$value"
                    return 0
                fi
            done
        done
        _warn "Invalid option"
    done
}

_setup_git_config() {
    local config_dir="$HOME/.config/git"
    local config_file="$config_dir/config.local"

    [ -d "$config_dir" ] || _echo_run mkdir -p "$config_dir"

    if [ -f "$config_file" ]; then
        _info "Git config already exists at $config_file"
        return 0
    fi

    _info "Enter your Git user name or real name (or press Enter to skip):"
    read "git_name?  → "

    if [ -z "$git_name" ]; then
        _warn "Skipped git config setup"
        return 0
    fi

    _info "Enter your Git email:"
    read "git_email?  → "

    _echo_run mkdir -p "$config_dir"
    cat > "$config_file" << EOF
[user]
    name = $git_name
    email = $git_email
EOF
    _info "Git user config created at $config_file"
}

main() {
    _info_long "Setting up macOS environment."

    _info "Converting mac-setup repository to SSH..."
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
    if [ -d "$SCRIPT_DIR/.git" ]; then
        _set_ssh_remote "$SCRIPT_DIR"
    fi

    _info_long "Checking for Homebrew..."
    if ! command -v brew &>/dev/null; then
        _info "Homebrew not found. Installing Homebrew..."
        _log "RUN" "/bin/bash -c \"\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\""
        if ! /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"; then
            _error "Failed to install Homebrew"
            return 1
        fi
        eval "$(/opt/homebrew/bin/brew shellenv)"
    else
        _info "Homebrew is already installed. Updating..."
        _echo_run brew update
    fi

    _info_long "Installing stow and just (prerequisites for dotfiles)..."
    _echo_run brew install stow just

    _info_long "Adding workspace and dotfiles..."
    [ -d "$HOME/Workspace" ] || {
        _info "Creating workspace directory as ~/Workspace..."
        _echo_run mkdir "$HOME/Workspace"
    }
    [ -d "$HOME/Workspace/dotfiles" ] || {
        _info "Cloning dotfiles repository to workspace..."
        _echo_run git clone https://github.com/Aapok0/dotfiles.git "$HOME/Workspace/dotfiles"
        _set_ssh_remote "$HOME/Workspace/dotfiles"
    }

    _info_long "Moving to dotfiles directory..."
    _echo_run cd "$HOME/Workspace/dotfiles"

    _info_long "Running full dotfiles setup via justfile (installs packages, stows configs, sets up shell, installs font)..."
    _echo_run just install

    _info "Setting up git user configuration..."
    _setup_git_config

    _info_long "Installing macOS apps..."

    _info "Installing Raycast..."
    _echo_run brew install --cask raycast

    _info "Installing Rectangle window manager..."
    _echo_run brew install --cask rectangle

    _info "Installing menu bar apps: hiddenbar, stats, and itsycal..."
    _echo_run brew install --cask hiddenbar stats itsycal

    choice=$(_ask_choice "Which password manager(s) do you want to install? (B)itwarden, (k)eepassxc, b(o)th, or (n)one: " \
        '|B|b|Bitwarden|bitwarden:bitwarden' \
        'K|k|Keepassxc|keepassxc:keepassxc' \
        'O|o|Both|both:both' \
        'N|n|None|none:none')

    case "$choice" in
        bitwarden)
            _info "Installing Bitwarden..."
            _echo_run brew install --cask bitwarden
            ;;
        keepassxc)
            _info "Installing KeePassXC..."
            _echo_run brew install --cask keepassxc
            ;;
        both)
            _info "Installing Bitwarden and KeePassXC..."
            _echo_run brew install --cask bitwarden keepassxc
            ;;
        none)
            _info "Skipping password manager installation"
            ;;
    esac

    choice=$(_ask_choice "Which Firefox version do you want to install? (R)egular, (d)eveloper edition, (b)oth, or (n)one: " \
        '|R|r|Regular|regular:regular' \
        'D|d|Developer|developer:developer' \
        'B|b|Both|both:both' \
        'N|n|None|none:none')

    case "$choice" in
        regular)
            _info "Installing Firefox..."
            _echo_run brew install --cask firefox
            ;;
        developer)
            _info "Installing Firefox Developer Edition..."
            _echo_run brew install --cask firefox@developer-edition
            ;;
        both)
            _info "Installing Firefox and Firefox Developer Edition..."
            _echo_run brew install --cask firefox firefox@developer-edition
            ;;
        none)
            _info "Skipping Firefox installation"
            ;;
    esac

    _info "Installing Docker Desktop..."
    _echo_run brew install --cask docker

    _info "Installing kubelogin..."
    _echo_run brew install Azure/kubelogin/kubelogin

    _info "Installing Wireshark..."
    _echo_run brew install --cask wireshark

    _info "Installing media apps: VLC and Spotify..."
    _echo_run brew install --cask vlc spotify

    _info "Installing Android File Transfer..."
    _echo_run brew install --cask android-file-transfer

    _log "INFO" "Setup completed. Log saved to: $LOGFILE"
    echo ""
    echo "SETUP FINISHED"
    echo "Post-setup tasks:"
    echo "1. Configure system settings (see instructions/system-settings.md)"
    echo "2. Configure Finder (see instructions/finder.md)"
    echo "3. Configure apps (see instructions/app-configuration.md)"
    echo "4. Log out and back in (or run 'exec zsh') to use zsh"
    echo "5. Open nvim and install plugins:"
    echo "   - nvim"
    echo "   - Let lazy.nvim install plugins"
    echo "   - :MasonInstall shellcheck shfmt stylua prettier ruff hadolint tflint ansible-lint"
    echo "6. Open tmux (tmux) and install plugins (ctrl+space I)"
}

main "$@" || { _error "Setup script failed!"; exit 1; }

